<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <defaults autowire="true" autoconfigure="true" public="false"/>

        <service id="Icreative\ContactPersonPlugin\\" resource="../../*"/>

        <service id="Icreative\ContactPersonPlugin\\Controller\\Api\\ContactPersonController">
            <argument type="service" id="icreative_contact_person.repository"/>
            <tag name="controller.service_arguments"/>
        </service>

        <service id="Icreative\ContactPersonPlugin\\Subscriber\\StorefrontSubscriber">
            <argument type="service" id="icreative_contact_person.repository"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Icreative\ContactPersonPlugin\\Core\\Content\\ContactPerson\\ContactPersonDefinition">
            <tag name="shopware.entity.definition" entity="icreative_contact_person"/>
        </service>
    </services>
</container>
